# PWRX Strava Sidecar - example environment

# Required for real Strava mode (not needed with --mock)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Output mode:
# - watch_folder: writes GPX files to output dir
# - import_api: writes GPX files and posts them to PWRX import API
PWRX_SIDECAR_MODE=watch_folder

# Where generated GPX files are stored
PWRX_SIDECAR_OUTPUT_DIR=./data/imports/watch/sidecar-strava

# Needed when mode=import_api
PWRX_SIDECAR_API_BASE=http://127.0.0.1:3001/api

# Sync scope tuning
PWRX_SIDECAR_LOOKBACK_DAYS=14
PWRX_SIDECAR_MAX_ACTIVITIES=200
PWRX_SIDECAR_DELAY_MS=120

# For local test without Strava credentials
PWRX_SIDECAR_MOCK=false
PWRX_SIDECAR_DRY_RUN=false
